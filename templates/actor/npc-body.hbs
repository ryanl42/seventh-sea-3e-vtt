{{!-- NPC Body --}}
<div class="npc-body">

  <div class="section-heading">Combat Aptitudes</div>
  <div class="aptitude-grid">

    <div class="aptitude-row">
      <label>Attack</label>
      <input type="number" name="system.combatAptitudes.attack" value="{{system.combatAptitudes.attack}}"
             min="0" max="10"
             {{#if (eq system.npcType "brute")}}disabled{{/if}}
             {{#unless isEditable}}disabled{{/unless}} />
    </div>

    <div class="aptitude-row">
      <label>Defence</label>
      <input type="number" name="system.combatAptitudes.defence" value="{{system.combatAptitudes.defence}}"
             min="0" max="10"
             {{#if (eq system.npcType "brute")}}disabled{{/if}}
             {{#unless isEditable}}disabled{{/unless}} />
             {{#if (eq system.npcType "brute")}}<span class="wounds-caption">Brute Squads have no Defence rating</span>{{/if}}
    </div>

    <div class="aptitude-row">
      <label>Damage</label>
      <input type="number" name="system.combatAptitudes.damage" value="{{system.combatAptitudes.damage}}"
             min="0" max="10"
             {{#if (eq system.npcType "brute")}}disabled{{/if}}
             {{#unless isEditable}}disabled{{/unless}} />
    </div>

    <div class="aptitude-row">
      <label>Toughness</label>
      <input type="number" name="system.combatAptitudes.toughness" value="{{system.combatAptitudes.toughness}}"
             min="0" max="10"
             {{#unless isEditable}}disabled{{/unless}} />
    </div>

    <div class="aptitude-row">
      <label>Manoeuvre</label>
      <input type="number" name="system.combatAptitudes.manoeuvre" value="{{system.combatAptitudes.manoeuvre}}"
             min="0" max="10"
             {{#unless isEditable}}disabled{{/unless}} />
    </div>

  </div>

  {{#if (eq system.npcType "brute")}}
  <div class="section-heading">Extended Action Tracker</div>
  <div class="extended-action-row">
    <label>Target</label>
    <input type="number" name="system.extendedAction.target" value="{{system.extendedAction.target}}" min="0"
           {{#unless isEditable}}disabled{{/unless}} />
    <label>Current</label>
    <input type="number" name="system.extendedAction.current" value="{{system.extendedAction.current}}" min="0"
           {{#unless isEditable}}disabled{{/unless}} />
  </div>
  {{/if}}

  <div class="section-heading">Wounds</div>

  {{#if (eq system.npcType "brute")}}

  <div class="wounds-row">
    <div class="wounds-label">Brutes Remaining</div>
    <div class="wound-track">
      {{#if system.bruteTrack.length}}
        <div class="wound-segment">
          {{#each system.bruteTrack}}
          <span class="wound-dot wound-dot-filled wound-dot-readonly" title="Brute {{@index}} — alive"></span>
          {{/each}}
        </div>
      {{else}}
        <span class="wounds-caption">Squad destroyed</span>
      {{/if}}
    </div>
  </div>

  {{else}}
  <div class="wounds-row">
    <div class="wounds-label">Wound Track</div>
    <div class="wound-track">
      {{#if system.wounds.trackLength}}
        {{#each system.wounds.track}}
        <div class="wound-segment">
          {{#each this.dots}}
          <span class="wound-dot {{#if this}}wound-dot-filled{{/if}} {{#unless ../../isEditable}}wound-dot-readonly{{/unless}}"
                title="Minor Wound {{@index}} + 1"></span>
          {{/each}}
          <label class="dw-box {{#if this.marked}}dw-marked{{/if}}">
            <input type="checkbox" name="system.wounds.dramatic.{{@index}}"
                   {{#if this.marked}}checked{{/if}}
                   {{#unless ../isEditable}}disabled{{/unless}} />
            <span class="dw-star">★</span>
          </label>
        </div>
        {{/each}}
      {{else}}
        <span class="wounds-caption">Assign a Toughness value to track wounds</span>
      {{/if}}
    </div>
  </div>

  {{/if}}

  <div class="wound-field">
    <label>Helpless</label>
    <input type="checkbox" name="system.wounds.helpless"
           {{#if system.wounds.helpless}}checked{{/if}}
           {{#unless isEditable}}disabled{{/unless}} />
  </div>

  <div class="section-heading">Notes</div>
  <textarea name="system.notes" rows="4"
            {{#unless isEditable}}disabled{{/unless}}>{{system.notes}}</textarea>

</div>
