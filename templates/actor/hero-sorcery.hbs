<div class="tab-panel" data-tab="sorcery">
<div class="sorcery-panel">

  <div class="section-heading-row">
    <div class="section-heading">Sorcery</div>
    {{#if isEditable}}
    <button type="button" class="create-advantage-btn" data-action="createSorcery">+ Add Tradition</button>
    {{/if}}
  </div>

  {{#if sorceryItems.length}}
    {{#each sorceryItems as |s|}}
    <div class="sorcery-tradition-block">

      <div class="sorcery-tradition-header">
        <span class="sorcery-tradition-name">{{s.traditionLabel}}</span>

        <div class="sorcery-resource-control">
          <span class="sorcery-resource-label">{{s.resourceLabel}}:</span>
          {{#if ../isEditable}}
          <button type="button" class="backlash-btn"
                  data-action="adjustResource"
                  data-item-id="{{s.id}}"
                  data-delta="-1">−</button>
          {{/if}}
          <span class="backlash-value {{#if s.resourceValue}}backlash-active{{/if}}">
            {{s.resourceValue}}
          </span>
          {{#if ../isEditable}}
          <button type="button" class="backlash-btn"
                  data-action="adjustResource"
                  data-item-id="{{s.id}}"
                  data-delta="1">+</button>
          {{/if}}
        </div>

        {{#if ../isEditable}}
        <div class="adv-controls">
          <a data-action="editSorcery" data-item-id="{{s.id}}" title="Edit">✎</a>
          <a data-action="deleteSorcery" data-item-id="{{s.id}}" title="Delete">✕</a>
        </div>
        {{/if}}
      </div>

      {{#if s.resourceValue}}
      <p class="backlash-warning">⚠ −{{s.resourceValue}} die{{#if (gt s.resourceValue 1)}}ce{{/if}} on all rolls</p>
      {{/if}}

      <div class="sorte-actions">
        {{!-- Each action already carries itemId from _prepareContext --}}
        {{#each s.actions as |action|}}
        <div class="sorte-action-row">
          <button type="button"
                  class="sorte-btn js-sorte-action"
                  data-item-id="{{action.itemId}}"
                  data-sorte-action="{{action.key}}">
            {{action.label}}
          </button>
          <span class="sorte-action-desc">{{action.hint}}</span>
        </div>
        {{/each}}
      </div>

      {{#if s.arcanaEntries.length}}
      <div class="arcana-items">
        {{#each s.arcanaEntries as |a|}}
        <div class="arcana-item-block">
          <div class="arcana-item-name">{{a.name}}</div>

          <div class="arcana-item-row">
            <button type="button"
                    class="sorte-btn sorte-minor js-arcana-action"
                    data-item-id="{{a.id}}"
                    data-arcana-tier="minor">
              ◈ Minor
            </button>
            <span class="arcana-item-desc">{{a.minorDesc}}</span>
          </div>

          <div class="arcana-item-row">
            <button type="button"
                    class="sorte-btn sorte-major js-arcana-action"
                    data-item-id="{{a.id}}"
                    data-arcana-tier="major">
              ★ Major
            </button>
            <span class="arcana-item-desc">{{a.majorDesc}}</span>
          </div>
        </div>
        {{/each}}
      </div>
      {{/if}}

    </div>
    {{/each}}
  {{else}}
    <p class="empty-list">No sorcery traditions. Click "+ Add Tradition" to add one.</p>
  {{/if}}

</div>
</div>
