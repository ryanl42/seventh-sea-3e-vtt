              data-skill="stealth" data-trait="finesse" data-label="Stealth">Stealth</span>
        <input type="number" name="system.skills.stealth.value"
               value="{{system.skills.stealth.value}}" min="0" max="5" {{#unless isEditable}}disabled{{/unless}} />
