<div class="npc-conditional-part">
{{#unless (eq system.npcType "brute")}}
<div class="tab-panel" data-tab="skills">
{{!-- Skills Panel --}}
<div class="skills-panel">
  <div class="section-heading">
    Skills
    <span class="section-sub">◈ = Specialty &nbsp;|&nbsp; click name to roll (Trait+Skill vs D2)</span>
  </div>

  <div class="skills-domains">

    <div class="skill-domain">
      <h3>Cunning</h3>
      <div class="skill-row">
        <input type="checkbox" name="system.skills.investigation.specialty" title="Specialty"
               {{#if system.skills.investigation.specialty}}checked{{/if}} {{#unless isEditable}}disabled{{/unless}} />
        <span class="skill-name rollable" data-action="rollSkill"
              data-skill="investigation" data-trait="wits" data-label="Investigation">Investigation</span>
        <input type="number" name="system.skills.investigation.value"
               value="{{system.skills.investigation.value}}" min="0" max="5" {{#unless isEditable}}disabled{{/unless}} />
      </div>
      <div class="skill-row">
        <input type="checkbox" name="system.skills.stealth.specialty" title="Specialty"
               {{#if system.skills.stealth.specialty}}checked{{/if}} {{#unless isEditable}}disabled{{/unless}} />
